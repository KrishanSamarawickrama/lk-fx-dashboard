# PostgreSQL
POSTGRES_USER=lkfx
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=lkfxdb
POSTGRES_PORT=5432

# App
APP_PORT=5000
ALLOWED_HOSTS=*

# Security
SECURITY_API_KEY=change-me-to-a-random-secret
SECURITY_ADMIN_PIN=1234

# Docker image (used by docker-compose and build script)
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE=youruser/lk-fx-dashboard
DOCKER_TAG=latest

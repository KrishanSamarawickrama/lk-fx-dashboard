<div class="bg-card/70 backdrop-blur-sm rounded-xl p-6 border border-edge">
    <h3 class="text-base font-semibold text-slate-100 mb-5">Source Comparison</h3>

    @if (Rates.Count > 0)
    {
        <div class="overflow-x-auto -mx-6 px-6">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-edge">
                        <th class="text-left py-2.5 pr-4 text-[10px] font-medium text-slate-600 uppercase tracking-[0.15em]">Source</th>
                        <th class="text-right py-2.5 px-4 text-[10px] font-medium text-slate-600 uppercase tracking-[0.15em]">Buy</th>
                        <th class="text-right py-2.5 px-4 text-[10px] font-medium text-slate-600 uppercase tracking-[0.15em]">Sell</th>
                        <th class="text-right py-2.5 px-4 text-[10px] font-medium text-slate-600 uppercase tracking-[0.15em]">Spread</th>
                        <th class="text-right py-2.5 pl-4 text-[10px] font-medium text-slate-600 uppercase tracking-[0.15em]">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rate in Rates)
                    {
                        var isBestBuy = rate.BuyingRate == Rates.Max(r => r.BuyingRate);
                        var isBestSell = rate.SellingRate == Rates.Min(r => r.SellingRate);
                        <tr class="border-b border-edge/40 hover:bg-elevated/30 transition-colors">
                            <td class="py-3 pr-4 font-medium text-slate-300">@rate.Source</td>
                            <td class="py-3 px-4 text-right font-mono tabular-nums @(isBestBuy ? "text-accent font-semibold" : "text-slate-300")">
                                @rate.BuyingRate.ToString("N2")
                            </td>
                            <td class="py-3 px-4 text-right font-mono tabular-nums @(isBestSell ? "text-accent font-semibold" : "text-slate-300")">
                                @rate.SellingRate.ToString("N2")
                            </td>
                            <td class="py-3 px-4 text-right font-mono tabular-nums text-slate-500">
                                @((rate.SellingRate - rate.BuyingRate).ToString("N2"))
                            </td>
                            <td class="py-3 pl-4 text-right text-slate-600 text-xs">
                                @rate.RateDate.ToString("yyyy-MM-dd")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-8 text-slate-600 text-sm">
            No rates available for comparison
        </div>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<ExchangeRate> Rates { get; set; } = [];
}

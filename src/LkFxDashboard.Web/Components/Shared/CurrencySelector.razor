@inject IRateService RateService
@inject NavigationManager Navigation

<div class="flex items-center gap-2.5">
    <label for="currency-select" class="text-[10px] font-medium text-slate-500 uppercase tracking-[0.15em]">Currency</label>
    <select id="currency-select"
            class="bg-surface border border-edge text-slate-200 rounded-lg px-3 py-1.5 text-sm
                   focus:ring-1 focus:ring-accent/30 focus:border-accent/50 outline-none
                   cursor-pointer hover:border-edge-hover transition-all"
            value="@SelectedCurrency"
            @onchange="OnCurrencyChanged">
        @foreach (var currency in Currencies)
        {
            <option value="@currency.Code">@currency.Code &mdash; @currency.Name</option>
        }
    </select>
</div>

@code {
    [Parameter]
    public string SelectedCurrency { get; set; } = "USD";

    [Parameter]
    public EventCallback<string> SelectedCurrencyChanged { get; set; }

    private IReadOnlyList<CurrencyInfo> Currencies { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Currencies = await RateService.GetCurrenciesAsync();
    }

    private async Task OnCurrencyChanged(ChangeEventArgs e)
    {
        var currency = e.Value?.ToString() ?? "USD";
        SelectedCurrency = currency;
        await SelectedCurrencyChanged.InvokeAsync(currency);
    }
}

<div class="flex items-center text-xs">
    @if (LastUpdated.HasValue)
    {
        var elapsed = DateTime.UtcNow - LastUpdated.Value;
        var isStale = elapsed.TotalHours > 25;

        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg
                     @(isStale ? "bg-caution/10 text-caution" : "bg-positive/10 text-positive")">
            <span class="relative flex h-1.5 w-1.5">
                @if (isStale)
                {
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-caution opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-caution"></span>
                }
                else
                {
                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-positive"></span>
                }
            </span>
            Updated @FormatTimeAgo(elapsed)
        </span>
    }
    else
    {
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-surface text-slate-600">
            No data yet
        </span>
    }
</div>

@code {
    [Parameter]
    public DateTime? LastUpdated { get; set; }

    private static string FormatTimeAgo(TimeSpan elapsed)
    {
        if (elapsed.TotalMinutes < 1) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        return $"{(int)elapsed.TotalDays}d ago";
    }
}

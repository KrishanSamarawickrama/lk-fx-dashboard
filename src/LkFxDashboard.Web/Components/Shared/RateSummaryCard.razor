@using LkFxDashboard.Core.Models

<div class="bg-card/70 backdrop-blur-sm rounded-xl p-5 border border-edge card-hover h-full">
    <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2.5">
            <div class="w-1 h-8 rounded-full @SourceAccentClass"></div>
            <h3 class="text-sm font-medium text-slate-300">@Source</h3>
        </div>
        @if (TrendDirection != 0)
        {
            <span class="text-[11px] font-medium font-mono px-2 py-0.5 rounded-md @(TrendDirection > 0 ? "bg-positive/10 text-positive" : "bg-negative/10 text-negative")">
                @(TrendDirection > 0 ? "+" : "")@TrendPercent.ToString("F2")%
            </span>
        }
    </div>

    @if (Rate is not null)
    {
        <div class="space-y-3">
            <div class="flex justify-between items-baseline">
                <span class="text-[10px] text-slate-600 uppercase tracking-[0.15em] font-medium">Buy</span>
                <span class="text-xl font-mono font-semibold text-slate-100 tabular-nums">
                    @Rate.BuyingRate.ToString("N2")
                </span>
            </div>
            <div class="flex justify-between items-baseline">
                <span class="text-[10px] text-slate-600 uppercase tracking-[0.15em] font-medium">Sell</span>
                <span class="text-xl font-mono font-semibold text-slate-100 tabular-nums">
                    @Rate.SellingRate.ToString("N2")
                </span>
            </div>
            <div class="flex justify-between items-baseline pt-2.5 border-t border-edge/60">
                <span class="text-[10px] text-slate-600 uppercase tracking-[0.15em] font-medium">Spread</span>
                <span class="text-xs font-mono text-slate-500 tabular-nums">
                    @((Rate.SellingRate - Rate.BuyingRate).ToString("N2"))
                </span>
            </div>
        </div>
    }
    else
    {
        <div class="flex items-center justify-center py-6 text-slate-600 text-sm">
            No data
        </div>
    }
</div>

@code {
    [Parameter]
    public string Source { get; set; } = string.Empty;

    [Parameter]
    public ExchangeRate? Rate { get; set; }

    [Parameter]
    public ExchangeRate? PreviousRate { get; set; }

    private int TrendDirection
    {
        get
        {
            if (Rate is null || PreviousRate is null) return 0;
            var diff = Rate.BuyingRate - PreviousRate.BuyingRate;
            return diff > 0 ? 1 : diff < 0 ? -1 : 0;
        }
    }

    private decimal TrendPercent
    {
        get
        {
            if (Rate is null || PreviousRate is null || PreviousRate.BuyingRate == 0) return 0;
            return (Rate.BuyingRate - PreviousRate.BuyingRate) / PreviousRate.BuyingRate * 100;
        }
    }

    private string SourceAccentClass => Source switch
    {
        "CBSL" => "bg-sky-400",
        "Standard Chartered" => "bg-teal-400",
        "Commercial Bank" => "bg-blue-400",
        "HSBC" => "bg-rose-400",
        "DFCC" => "bg-amber-400",
        "HNB" => "bg-violet-400",
        "BOC" => "bg-orange-400",
        "Sampath" => "bg-emerald-400",
        _ => "bg-slate-400"
    };
}

@using ApexCharts

<div class="bg-card/70 backdrop-blur-sm rounded-xl p-6 border border-edge">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
        <h3 class="text-base font-semibold text-slate-100">
            Rate History
            <span class="text-slate-500 font-normal text-sm ml-1">LKR / @Currency</span>
        </h3>
        <div class="flex gap-1 bg-surface rounded-lg p-0.5">
            @foreach (var option in new[] { 30, 60, 90 })
            {
                var days = option;
                <button class="px-3 py-1 text-xs font-medium rounded-md transition-all
                               @(SelectedDays == days
                                   ? "bg-accent text-slate-950 shadow-sm"
                                   : "text-slate-500 hover:text-slate-300")"
                        @onclick="() => OnDaysChanged(days)">
                    @days D
                </button>
            }
        </div>
    </div>

    @if (ChartData.Count > 0)
    {
        <ApexChart TItem="ChartPoint"
                   Options="ChartOptions"
                   Height="350"
                   @key="chartVersion">
            @foreach (var source in ChartData.GroupBy(d => d.Source))
            {
                <ApexPointSeries TItem="ChartPoint"
                                 Items="source.ToList()"
                                 Name="@source.Key"
                                 SeriesType="SeriesType.Line"
                                 XValue="p => p.Date.ToDateTime(TimeOnly.MinValue)"
                                 YValue="p => p.Rate" />
            }
        </ApexChart>
    }
    else
    {
        <div class="flex items-center justify-center h-[350px] text-slate-600 text-sm">
            No historical data available
        </div>
    }
</div>

@code {
    [Parameter]
    public string Currency { get; set; } = "USD";

    [Parameter]
    public IReadOnlyList<ExchangeRate> HistoryData { get; set; } = [];

    [Parameter]
    public int SelectedDays { get; set; } = 30;

    [Parameter]
    public EventCallback<int> SelectedDaysChanged { get; set; }

    private List<ChartPoint> ChartData { get; set; } = [];

    private ApexChartOptions<ChartPoint> ChartOptions { get; set; } = new();

    private int chartVersion;
    private IReadOnlyList<ExchangeRate>? lastHistoryData;

    protected override void OnInitialized()
    {
        ConfigureChart();
    }

    protected override void OnParametersSet()
    {
        ChartData = HistoryData.Select(r => new ChartPoint
        {
            Date = r.RateDate,
            Rate = r.BuyingRate,
            Source = r.Source
        }).ToList();

        if (!ReferenceEquals(HistoryData, lastHistoryData))
        {
            lastHistoryData = HistoryData;
            chartVersion++;
        }
    }

    private void ConfigureChart()
    {
        ChartOptions = new ApexChartOptions<ChartPoint>
        {
            Chart = new Chart
            {
                Background = "transparent",
                Toolbar = new Toolbar { Show = false },
                Zoom = new Zoom { Enabled = true }
            },
            Theme = new Theme { Mode = Mode.Dark },
            Grid = new Grid
            {
                BorderColor = "#1a2744",
                Xaxis = new GridXAxis { Lines = new Lines { Show = false } }
            },
            Stroke = new Stroke
            {
                Curve = Curve.Smooth,
                Width = 2
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Labels = new XAxisLabels
                {
                    Style = new AxisLabelStyle { Colors = "#64748b" }
                }
            },
            Yaxis =
            [
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Style = new AxisLabelStyle { Colors = "#64748b" }
                    }
                }
            ],
            Tooltip = new Tooltip
            {
                Theme = Mode.Dark
            },
            Colors = ["#38bdf8", "#2dd4bf", "#818cf8", "#fb923c", "#f472b6", "#fbbf24", "#4ade80", "#f87171"]
        };
    }

    private async Task OnDaysChanged(int days)
    {
        SelectedDays = days;
        await SelectedDaysChanged.InvokeAsync(days);
    }

    public class ChartPoint
    {
        public DateOnly Date { get; set; }
        public decimal Rate { get; set; }
        public string Source { get; set; } = string.Empty;
    }
}

@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="flex items-center justify-center min-h-[60vh]">
    <div class="bg-card/70 backdrop-blur-sm rounded-xl p-8 border border-edge max-w-lg text-center">
        <h1 class="text-2xl font-bold text-negative mb-4">An error occurred</h1>
        <p class="text-slate-400 mb-6">
            Sorry, something went wrong processing your request.
        </p>

        @if (ShowRequestId)
        {
            <p class="text-sm text-slate-500">
                <span class="font-medium">Request ID:</span>
                <code class="font-mono text-slate-400">@RequestId</code>
            </p>
        }

        <a href="/" class="inline-block mt-6 px-6 py-2 bg-accent hover:bg-accent-dim text-slate-950 font-medium rounded-lg transition-colors">
            Back to Dashboard
        </a>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

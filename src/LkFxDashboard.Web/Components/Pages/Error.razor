@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="flex items-center justify-center min-h-[60vh]">
    <div class="bg-gray-900 rounded-2xl p-8 border border-gray-800 max-w-lg text-center">
        <h1 class="text-2xl font-bold text-rose-400 mb-4">An error occurred</h1>
        <p class="text-gray-400 mb-6">
            Sorry, something went wrong processing your request.
        </p>

        @if (ShowRequestId)
        {
            <p class="text-sm text-gray-500">
                <span class="font-medium">Request ID:</span>
                <code class="font-mono text-gray-400">@RequestId</code>
            </p>
        }

        <a href="/" class="inline-block mt-6 px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-colors">
            Back to Dashboard
        </a>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

@page "/"
@inject IRateService RateService
@inject ILogger<Dashboard> Logger
@inject IOptions<SecurityOptions> SecurityOpts

<PageTitle>LK FX Dashboard</PageTitle>

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-100">Exchange Rates</h1>
            <p class="text-sm text-gray-500 mt-1">LKR per 1 @selectedCurrency</p>
        </div>
        <div class="flex items-center gap-4 flex-wrap">
            <CurrencySelector SelectedCurrency="@selectedCurrency"
                              SelectedCurrencyChanged="OnCurrencyChanged" />
            <LastUpdatedBadge LastUpdated="@lastUpdated" />
            @if (isAdmin)
            {
                <RefreshButton IsRefreshing="@isRefreshing" OnRefresh="OnRefresh" />
            }
            else if (showPinEntry)
            {
                <div class="flex items-center gap-2">
                    <input type="password" maxlength="20" placeholder="Enter PIN"
                           class="w-28 px-3 py-2 bg-gray-800 border border-gray-600 rounded-lg text-sm text-gray-100 placeholder-gray-500 focus:outline-none focus:border-emerald-500"
                           @bind="enteredPin" @bind:event="oninput"
                           @onkeydown="OnPinKeyDown" />
                    <button class="px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors"
                            @onclick="VerifyPin">
                        OK
                    </button>
                    <button class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-lg transition-colors"
                            @onclick="() => showPinEntry = false">
                        Cancel
                    </button>
                </div>
                @if (pinError is not null)
                {
                    <span class="text-rose-400 text-xs">@pinError</span>
                }
            }
            else
            {
                <button class="inline-flex items-center gap-2 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm font-medium rounded-lg transition-colors"
                        @onclick="() => showPinEntry = true">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <span>Admin</span>
                </button>
            }
        </div>
    </div>

    @if (errorMessage is not null)
    {
        <div class="bg-rose-900/30 border border-rose-700 rounded-xl p-4 text-rose-300 text-sm">
            @errorMessage
        </div>
    }

    <!-- Rate Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        @foreach (var source in ScraperSource.All)
        {
            var rate = latestRates.FirstOrDefault(r => r.Source == source);
            var prevRate = previousRates.FirstOrDefault(r => r.Source == source);
            <RateSummaryCard Source="@source" Rate="@rate" PreviousRate="@prevRate" />
        }
    </div>

    <!-- History Chart -->
    <HistoryChart Currency="@selectedCurrency"
                  HistoryData="@historyData"
                  SelectedDays="@selectedDays"
                  SelectedDaysChanged="OnDaysChanged" />

    <!-- Source Comparison Table -->
    <SourceComparisonTable Rates="@latestRates" />
</div>

@code {
    private string selectedCurrency = "USD";
    private int selectedDays = 30;
    private bool isRefreshing;
    private DateTime? lastUpdated;
    private string? errorMessage;

    private bool isAdmin;
    private bool showPinEntry;
    private string enteredPin = string.Empty;
    private string? pinError;

    private IReadOnlyList<ExchangeRate> latestRates = [];
    private IReadOnlyList<ExchangeRate> previousRates = [];
    private IReadOnlyList<ExchangeRate> historyData = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        latestRates = await RateService.GetLatestRatesAsync(selectedCurrency);
        historyData = await RateService.GetHistoryAsync(selectedCurrency, selectedDays);

        // Get previous day's rates for trend comparison
        var allHistory = await RateService.GetHistoryAsync(selectedCurrency, 2);
        var latestDate = latestRates.FirstOrDefault()?.RateDate;
        if (latestDate.HasValue)
        {
            previousRates = allHistory
                .Where(r => r.RateDate < latestDate.Value)
                .ToList();
        }

        lastUpdated = latestRates
            .Select(r => (DateTime?)r.CollectedAt)
            .Max();
    }

    private async Task OnCurrencyChanged(string currency)
    {
        selectedCurrency = currency;
        await LoadData();
    }

    private async Task OnDaysChanged(int days)
    {
        selectedDays = days;
        historyData = await RateService.GetHistoryAsync(selectedCurrency, selectedDays);
    }

    private void VerifyPin()
    {
        var correctPin = SecurityOpts.Value.AdminPin;
        if (string.Equals(enteredPin, correctPin, StringComparison.Ordinal))
        {
            isAdmin = true;
            showPinEntry = false;
            pinError = null;
            enteredPin = string.Empty;
        }
        else
        {
            pinError = "Incorrect PIN";
        }
    }

    private void OnPinKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            VerifyPin();
        }
    }

    private async Task OnRefresh()
    {
        isRefreshing = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            await RateService.RefreshRatesAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during refresh");
            errorMessage = $"Refresh failed: {ex.Message}";
        }
        finally
        {
            isRefreshing = false;
        }
    }
}
